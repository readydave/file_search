# .gitignore

# -----------------
# Virtual Environment
# -----------------
# Never commit the virtual environment folder. This is specific to each
# user's machine and can be rebuilt from requirements.txt.
.venv/

# -----------------
# Python Cache & Bytecode
# -----------------
# These files are generated automatically by Python at runtime.
__pycache__/
*.pyc
*.pyo
*.pyd

# -----------------
# IDE / Editor Configuration
# -----------------
# User-specific settings for editors like VS Code.
.vscode/
.idea/

# -----------------
# Operating System Files
# -----------------
# Common metadata files generated by Windows and macOS.
.DS_Store
Thumbs.db

# -----------------
# Other
# -----------------
# Any local log files or build artifacts.
*.log
dist/
build/
*.egg-info/
